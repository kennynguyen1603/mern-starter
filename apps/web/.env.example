# ─── Token Refresh ───────────────────────────────────────────────────────────

# Access token lifetime in milliseconds.
# Must match JWT_SECRET_ACCESS_TOKEN_EXP on the backend.
# 15 minutes = 900000 ms  |  30 minutes = 1800000 ms
VITE_ACCESS_TOKEN_EXP_MS=900000

# ─── Dev Server (optional) ───────────────────────────────────────────────────

# Port for the Vite development server (default: 5173)
VITE_PORT=5173

# Backend base URL used by the Vite proxy (default: http://localhost:8080)
# All /api/v1/* requests are forwarded here during development.
VITE_API_URL=http://localhost:8080

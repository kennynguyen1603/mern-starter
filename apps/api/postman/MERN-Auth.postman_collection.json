              }
            },
            {
              "name": "Refresh Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                      "",
                      "if (pm.response.code === 200) {",
                      "    let accessToken = '';",
                      "    let refreshToken = '';",
                      "",
                      "    pm.response.headers.each(header => {",
                      "        if (header.key.toLowerCase() === 'set-cookie') {",
                      "            const val = header.value;",
                      "            const atMatch = val.match(/^accessToken=([^;]+)/);",
                      "            const rtMatch = val.match(/^refreshToken=([^;]+)/);",
                      "            if (atMatch) accessToken = atMatch[1];",
                      "            if (rtMatch) refreshToken = rtMatch[1];",
                      "        }",
                      "    });",
                      "",
                      "    if (!accessToken) accessToken = pm.cookies.get('accessToken') || '';",
                      "    if (!refreshToken) refreshToken = pm.cookies.get('refreshToken') || '';",
                      "",
                      "    if (accessToken) pm.environment.set('accessToken', accessToken);",
                      "    if (refreshToken) pm.environment.set('refreshToken', refreshToken);",
                      "",
                      "    console.log('🔄 Tokens rotated successfully');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/refresh",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "{{apiVersion}}", "auth", "refresh"]
                },
                "description": "Lấy accessToken mới bằng refreshToken (Refresh Token Rotation — token cũ bị revoke).\nRefreshToken được gửi tự động qua Cookie header từ collection pre-request script."
              }
            },

# ─── Server ──────────────────────────────────────────────────────────────────

PORT=8080
NODE_ENV=development

# URL of the frontend (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ─────────────────────────────────────────────────────────────────

# Connection string — Atlas example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
# Local example: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Database name
DB_NAME=mern_db

# ─── Encryption ──────────────────────────────────────────────────────────────

# 32+ character random string used for symmetric encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_me_to_a_32_character_random_string_here

# ─── JWT ─────────────────────────────────────────────────────────────────────

# Use strong, unique secrets in production (min 32 chars recommended)
JWT_SECRET_ACCESS_TOKEN=your_access_token_secret_here
# Format: <number><unit> where unit = s | m | h | d
JWT_SECRET_ACCESS_TOKEN_EXP=15m

JWT_SECRET_REFRESH_TOKEN=your_refresh_token_secret_here
JWT_SECRET_REFRESH_TOKEN_EXP=7d

# ─── Redis ───────────────────────────────────────────────────────────────────

# Option A: full connection URL (takes priority)
# Redis Cloud: redis://default:<password>@<host>:<port>
# Local:       redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Option B: host + port (used only if REDIS_URL is not set)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────

# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include the callback URL below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── Email (Resend) ───────────────────────────────────────────────────────────

# Create an API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address — must be from a verified domain in Resend
FROM_EMAIL=no-reply@yourdomain.com

# ─── Cloudinary (file uploads) ───────────────────────────────────────────────

# Find these in your Cloudinary dashboard: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
